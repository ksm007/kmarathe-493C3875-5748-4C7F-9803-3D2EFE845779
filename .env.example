DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/secure_tasks?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
PORT=3000
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
OPENAI_API_KEY=
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
MAX_CHAT_REQUESTS_PER_MINUTE=20
CANARY_TOKEN=__SYSTEM_BOUNDARY_42__
# Per-IP rate limit on auth + invite routes (login, register, password reset, invitations)
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_MAX=10
# Higher per-IP limit for authenticated bulk invite creation (POST /invitations)
INVITE_RATE_LIMIT_TTL_SECONDS=60
INVITE_RATE_LIMIT_MAX=50
# Per-account brute-force protection on login
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
# Express 'trust proxy' so the rate limiter sees the real client IP behind a
# proxy/load balancer/ingress. Number of proxy hops to trust (1 = single
# nginx/ingress); set higher for multiple hops, a verbatim value like 'loopback'
# or a CIDR, or false to disable. Defaults to 1.
TRUST_PROXY=1

# Attachment storage (image attachments)
# Provider: "local" for development (disk), "cloudinary" for production (cloud image storage). See ADR 0024.
ATTACHMENT_STORAGE_PROVIDER=local
# Local-disk provider: directory for stored attachments (defaults to <cwd>/var/attachments).
ATTACHMENT_STORAGE_DIR=
# Cloudinary provider (required when ATTACHMENT_STORAGE_PROVIDER=cloudinary):
# Either set CLOUDINARY_URL (cloudinary://<api_key>:<api_secret>@<cloud_name>)...
CLOUDINARY_URL=
# ...or set the three values explicitly instead of CLOUDINARY_URL:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Note: an S3-compatible object-storage provider could be added later behind the
# same AttachmentStorageService seam (e.g. ATTACHMENT_STORAGE_PROVIDER=s3); not implemented yet.

# Google sign-in (API / backend)
# Required for server-side ID token verification via google-auth-library.
# Create an OAuth 2.0 client ID at https://console.cloud.google.com/ under
# APIs & Services > Credentials. Set the authorized JavaScript origins to your
# frontend URL (e.g. http://localhost:4200). No OAuth callback URL is needed:
# the frontend uses the Google Identity Services (GIS) popup/One Tap flow and
# POSTs the ID token to POST /auth/google for server-side verification.
GOOGLE_CLIENT_ID=

# Google sign-in (frontend / Vite)
# Must match GOOGLE_CLIENT_ID above. Prefixed with VITE_ so it is embedded
# into the frontend bundle at build time. If omitted, the Google button is hidden.
VITE_GOOGLE_CLIENT_ID=
