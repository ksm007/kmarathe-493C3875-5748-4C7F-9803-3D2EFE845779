DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/secure_tasks?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
PORT=3000
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
OPENAI_API_KEY=
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
MAX_CHAT_REQUESTS_PER_MINUTE=20
CANARY_TOKEN=__SYSTEM_BOUNDARY_42__
# Per-IP rate limit on auth + invite routes (login, register, password reset, invitations)
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_MAX=10
# Per-account brute-force protection on login
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
# Express 'trust proxy' so the rate limiter sees the real client IP behind a
# proxy/load balancer/ingress. true/false, a hop count, or a verbatim value
# like 'loopback' or a CIDR. Defaults to true; set false for direct exposure.
TRUST_PROXY=true
