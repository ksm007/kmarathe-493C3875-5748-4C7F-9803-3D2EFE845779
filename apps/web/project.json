{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/web", "{workspaceRoot}/apps/web/.output"],
      "options": {
        "command": "vite build --config apps/web/vite.config.mts"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "vite dev --config apps/web/vite.config.mts --host 0.0.0.0"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --project apps/web/tsconfig.json --noEmit",
          "tsc --project apps/web/tsconfig.spec.json --noEmit"
        ],
        "parallel": false
      }
    },
    "preview": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview --config apps/web/vite.config.mts --host 0.0.0.0"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/web/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
